-- Fix Lag
local fixLagEnabled=true
local originalQuality=Lighting.QualityLevel
local originalShadowMode=Lighting.ShadowSoftness
local originalGlobalShadows=Lighting.GlobalShadows

local function applyFixLag(enabled)
    if enabled then
        Lighting.QualityLevel=Enum.QualityLevel.Level01
        Lighting.ShadowSoftness=0
        Lighting.GlobalShadows=false
        Workspace.Decal.Transparency=1
        workspace.Terrain.WaterWaveSize=0
        workspace.Terrain.WaterReflectance=0
        workspace.Terrain.WaterTransparency=0
        for _,v in pairs(Workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") then v.Enabled=false end
        end
    else
        Lighting.QualityLevel=originalQuality
        Lighting.ShadowSoftness=originalShadowMode
        Lighting.GlobalShadows=originalGlobalShadows
        workspace.Terrain.WaterWaveSize=0.5
        workspace.Terrain.WaterReflectance=0.5
        workspace.Terrain.WaterTransparency=0.5
    end
end

