    local function updateUptime()
        local elapsed=os.time()-serverStartTime
        local hours=math.floor(elapsed/3600)
        local minutes=math.floor((elapsed%3600)/60)
        local seconds=elapsed%60
        if hours>0 then uptimeRow.SetValue(string.format("%dh %dm %ds",hours,minutes,seconds))
        elseif minutes>0 then uptimeRow.SetValue(string.format("%dm %ds",minutes,seconds))
        else uptimeRow.SetValue(string.format("%ds",seconds)) end
    end
