    FlyDownBtn.MouseButton1Down:Connect(function() TouchInput.down = true end)
    FlyDownBtn.MouseButton1Up:Connect(function() TouchInput.down = false end)
end

local function RemoveMobileFlyButtons()
    if ScreenGui then ScreenGui:Destroy() end
    ScreenGui = nil
end

local function StartFly()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid")
    local rootPart = character:WaitForChild("HumanoidRootPart")
    
    FlyBodyVelocity = Instance.new("BodyVelocity")
    FlyBodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    FlyBodyVelocity.Velocity = Vector3.zero
    FlyBodyVelocity.Parent = rootPart
    
    FlyBodyGyro = Instance.new("BodyGyro")
    FlyBodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    FlyBodyGyro.CFrame = Camera.CFrame
    FlyBodyGyro.Parent = rootPart
    
    humanoid.PlatformStand = true
    
    if UserInputService.TouchEnabled then
        CreateMobileFlyButtons()
    end
    
    FlyConnection = RunService.RenderStepped:Connect(function()
        if FlyEnabled and character and character.Parent and FlyBodyVelocity and FlyBodyGyro then
            local cameraCFrame = Camera.CFrame
            local moveDir = Vector3.zero
            
            -- PC Input
            if not UserInputService.TouchEnabled then
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                    moveDir = moveDir + cameraCFrame.LookVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                    moveDir = moveDir - cameraCFrame.LookVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                    moveDir = moveDir + Vector3.new(0, 1, 0)
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
                    moveDir = moveDir - Vector3.new(0, 1, 0)
                end
            end
            
            -- Mobile Input
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid then
                local moveVector = humanoid.MoveDirection
                if moveVector.Magnitude > 0 then
                    local forward = cameraCFrame.LookVector
                    forward = Vector3.new(forward.X, 0, forward.Z).Unit
                    local right = cameraCFrame.RightVector
                    right = Vector3.new(right.X, 0, right.Z).Unit
                    
                    moveDir = moveDir + forward * moveVector.Z
                    moveDir = moveDir + right * moveVector.X
                end
            end
            
            if TouchInput.up then moveDir = moveDir + cameraCFrame.LookVector end
            if TouchInput.down then moveDir = moveDir - cameraCFrame.LookVector end
            
            if moveDir.Magnitude > 0 then
                FlyBodyVelocity.Velocity = moveDir.Unit * FlySpeed
            else
                FlyBodyVelocity.Velocity = Vector3.zero
            end
            
            FlyBodyGyro.CFrame = CFrame.new(rootPart.Position, rootPart.Position + cameraCFrame.LookVector)
        end
    end)
end

local function StopFly()
    if FlyConnection then FlyConnection:Disconnect(); FlyConnection = nil end
    if FlyBodyVelocity then FlyBodyVelocity:Destroy(); FlyBodyVelocity = nil end
    if FlyBodyGyro then FlyBodyGyro:Destroy(); FlyBodyGyro = nil end
    
    RemoveMobileFlyButtons()
    TouchInput = {up = false, down = false}
    
    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then humanoid.PlatformStand = false end
    end
end

-- ## GOD MODE ##
local function EnableGodMode()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid")
    
    -- Cách 1: Set Health lên vô hạn mỗi frame
    GodModeConnection = RunService.RenderStepped:Connect(function()
        if GodModeEnabled and humanoid and humanoid.Parent then
            humanoid.Health = humanoid.MaxHealth
        end
    end)
    
    -- Bảo vệ nhân vật mới khi respawn
    LocalPlayer.CharacterAdded:Connect(function(newCharacter)
        if GodModeEnabled then
            local newHumanoid = newCharacter:WaitForChild("Humanoid")
            GodModeConnection:Disconnect()
            GodModeConnection = RunService.RenderStepped:Connect(function()
                if GodModeEnabled and newHumanoid and newHumanoid.Parent then
                    newHumanoid.Health = newHumanoid.MaxHealth
                end
            end)
        end
    end)
end

local function ToggleGodMode(state)
    GodModeEnabled = state
    if state then
        EnableGodMode()
    else
        if GodModeConnection then
            GodModeConnection:Disconnect()
            GodModeConnection = nil
        end
    end
end

-- ## FOV CIRCLE UPDATE ##
local function UpdateFOVCircle()
    if FOV_VISIBLE and AimbotEnabled then
        FOVCircle.Visible = true
        FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        FOVCircle.Radius = FOV_RADIUS
    else
        FOVCircle.Visible = false
    end
end

-- ## PLAYER CONNECTIONS ##
Players.PlayerAdded:Connect(function(player)
    if ESPEnabled then CreateESP(player) end
    if HitboxEnabled then CreateHitbox(player) end
end)

Players.PlayerRemoving:Connect(function(player)
    if ESPObjects[player] then
        if ESPObjects[player].DistanceConnection then
            ESPObjects[player].DistanceConnection:Disconnect()
        end
        for _, obj in pairs(ESPObjects[player]) do
            if obj and obj:IsA("Highlight") then obj:Destroy() end
        end
        ESPObjects[player] = nil
    end
    if HitboxObjects[player] then
        for _, obj in pairs(HitboxObjects[player]) do
            if obj then obj:Destroy() end
        end
        HitboxObjects[player] = nil
    end
end)

-- ## MAIN LOOP ##
RunService.RenderStepped:Connect(function()
    UpdateFOVCircle()
end)

