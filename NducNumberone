-- ## HITBOX ##
local function CreateHitbox(player)
    if player == LocalPlayer then return end
    
    local function setupHitbox(character)
        if not character then return end
        
        if HitboxObjects[player] then
            for _, obj in pairs(HitboxObjects[player]) do
                if obj then obj:Destroy() end
            end
        end
        HitboxObjects[player] = {}
        
        local head = character:WaitForChild("Head", 5)
        if head then
            local hitbox = Instance.new("Part")
            hitbox.Name = "HitboxExpander"
            hitbox.Transparency = 1
            hitbox.CanCollide = false
            hitbox.CanQuery = false
            hitbox.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
            hitbox.Massless = true
            hitbox.Parent = character
            local weld = Instance.new("WeldConstraint")
            weld.Part0 = hitbox
            weld.Part1 = head
            weld.Parent = hitbox
            HitboxObjects[player].HeadHitbox = hitbox
        end
        
        local hrp = character:WaitForChild("HumanoidRootPart", 5)
        if hrp then
            local bodyHitbox = Instance.new("Part")
            bodyHitbox.Name = "BodyHitbox"
            bodyHitbox.Transparency = 1
            bodyHitbox.CanCollide = false
            bodyHitbox.CanQuery = false
            bodyHitbox.Size = Vector3.new(HitboxSize, HitboxSize * 1.5, HitboxSize)
            bodyHitbox.Massless = true
            bodyHitbox.Parent = character
            local weld = Instance.new("WeldConstraint")
            weld.Part0 = bodyHitbox
            weld.Part1 = hrp
            weld.Parent = bodyHitbox
            HitboxObjects[player].BodyHitbox = bodyHitbox
        end
    end
    
    if player.Character then
        setupHitbox(player.Character)
    end
    
    player.CharacterAdded:Connect(function(character)
        if HitboxEnabled then
            setupHitbox(character)
        end
    end)
end

local function ToggleHitbox(state)
    HitboxEnabled = state
    if state then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                CreateHitbox(player)
            end
        end
    else
        for player, objects in pairs(HitboxObjects) do
            for _, obj in pairs(objects) do
                if obj then obj:Destroy() end
            end
        end
        HitboxObjects = {}
    end
end

-- ## AIMBOT ##
local function GetClosestPlayerInFOV()
    local closestPlayer = nil
    local shortestDistance = FOV_RADIUS
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local humanoid = player.Character:FindFirstChild("Humanoid")
            local head = player.Character:FindFirstChild("Head")
            
            if humanoid and humanoid.Health > 0 and head then
                local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                
                if onScreen then
                    local distanceFromCenter = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                    if distanceFromCenter <= FOV_RADIUS and distanceFromCenter < shortestDistance then
                        shortestDistance = distanceFromCenter
                        closestPlayer = player
                    end
                end
            end
        end
    end
    
    return closestPlayer
end

-- Mỗi lần bấm chuột trái là ghim 1 lần
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 and AimbotEnabled then
        local target = GetClosestPlayerInFOV()
        if target and target.Character and target.Character:FindFirstChild("Head") then
            local head = target.Character.Head
            local lookAt = (head.Position - Camera.CFrame.Position).Unit
            local targetCFrame = CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + lookAt)
            Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, SMOOTHING)
        end
    end
end)

-- ## ESP ##
local function CreateESP(player)
    if player == LocalPlayer then return end
    
    local function setupESP(character)
        if not character then return end
        
        if ESPObjects[player] then
            for _, obj in pairs(ESPObjects[player]) do
                if obj then obj:Destroy() end
            end
        end
        ESPObjects[player] = {}
        
        local highlight = Instance.new("Highlight")
        highlight.Name = "PlayerESP"
        highlight.FillColor = Color3.fromRGB(0, 255, 0)
        highlight.OutlineColor = Color3.fromRGB(0, 200, 0)
        highlight.FillTransparency = 0.3
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Adornee = character
        highlight.Parent = character
        ESPObjects[player].Highlight = highlight
        
        local distanceCheck
        distanceCheck = RunService.RenderStepped:Connect(function()
            if not character or not character.Parent then
                distanceCheck:Disconnect()
                return
            end
            if ESPEnabled and ESPObjects[player] and ESPObjects[player].Highlight then
                local myChar = LocalPlayer.Character
                local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
                local targetHRP = character:FindFirstChild("HumanoidRootPart")
                if myHRP and targetHRP then
                    local distance = (myHRP.Position - targetHRP.Position).Magnitude
                    ESPObjects[player].Highlight.Enabled = (distance <= ESP_MAX_DISTANCE)
                end
            end
        end)
        ESPObjects[player].DistanceConnection = distanceCheck
    end
    
    -- ESP sẽ tự hiện lại khi địch hồi sinh
    if player.Character then
        setupESP(player.Character)
    end
    
    player.CharacterAdded:Connect(function(character)
        if ESPEnabled then
            task.wait(0.5) -- Đợi character load
            setupESP(character)
        end
    end)
end

local function ToggleESP(state)
    ESPEnabled = state
    if state then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                CreateESP(player)
            end
        end
    else
        for player, objects in pairs(ESPObjects) do
            if objects.DistanceConnection then
                objects.DistanceConnection:Disconnect()
            end
            for _, obj in pairs(objects) do
                if obj and obj:IsA("Highlight") then obj:Destroy() end
            end
            ESPObjects[player] = nil
        end
    end
end

-- ## FLY ##
local function CreateMobileFlyButtons()
    if ScreenGui then ScreenGui:Destroy() end
    
    ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "FlyControls"
    ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    
    FlyUpBtn = Instance.new("TextButton")
