-- Cấu hình
local FOV_RADIUS = 150
local SMOOTHING = 1          -- 1 = ghim đầu 100%
local FOV_VISIBLE = true
local FOV_COLOR = Color3.fromRGB(255, 255, 255)

local ESPEnabled = false
local ESPObjects = {}

-- Tạo vòng tròn FOV
