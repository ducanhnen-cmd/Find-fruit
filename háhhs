local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/liebertsx/Tora-Library/main/src/librarynew",true))()
local tab = library:CreateWindow("NducNo1")

-- Kill Aura - Tấn công TẤT CẢ (Mob + NPC + Nguyên Liệu)
-- Mob/NPC: Gây sát thương dựa trên Level & chỉ số của NGƯỜI CHƠI (không giết ngay)
-- Nguyên liệu: Phá hủy ngay lập tức

local AttackRange = 800
local AttackCooldown = 0.5  -- Tăng lên 1 chút để thấy rõ sát thương từ từ (có thể giảm nếu muốn nhanh hơn)
local AttackHPPercent = 100
local AttackMode = "Vector3" -- "Vector3" hoặc "Model"
local FireAbilitiesEnabled = true
local KillAuraEnabled = true

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local RS = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

-- Gộp tất cả thư mục cần farm vào 1 danh sách
local TargetFolders = {}

-- Thêm thư mục Mob
local mobsFolder = workspace:FindFirstChild("Mobs") or workspace:FindFirstChild("NPCs")
if mobsFolder then table.insert(TargetFolders, mobsFolder) end

-- Thêm thư mục Nguyên Liệu (cỏ, cây, đá, quặng...)
local farmFolder = workspace:FindFirstChild("Resources")
    or workspace:FindFirstChild("Nodes")
    or workspace:FindFirstChild("Ores")
    or workspace:FindFirstChild("Trees")
    or workspace:FindFirstChild("Rocks")
    or workspace:FindFirstChild("Grass")
    or workspace:FindFirstChild("Farms")
if farmFolder then table.insert(TargetFolders, farmFolder) end

-- Nếu không tìm thấy thư mục nào, dùng workspace
if #TargetFolders == 0 then
    table.insert(TargetFolders, workspace)
    warn("[Kill Aura] Không tìm thấy thư mục cụ thể, dùng toàn bộ workspace")
end

print("[Kill Aura] Target folders: " .. #TargetFolders)

-- Remote
local hitRemote = nil
local abilityRemote = nil
local damageRemote = nil -- Remote gây sát thương theo số (tùy game)

local function findRemotes()
    pcall(function()
        hitRemote = RS:WaitForChild("CombatSystem", 10)
            and RS.CombatSystem:WaitForChild("Remotes", 5)
            and RS.CombatSystem.Remotes:WaitForChild("RequestHit", 5)
    end)

    pcall(function()
        abilityRemote = RS:WaitForChild("AbilitySystem", 10)
            and RS.AbilitySystem:WaitForChild("Remotes", 5)
            and RS.AbilitySystem.Remotes:WaitForChild("RequestAbility", 5)
    end)
    
    -- Thử tìm Remote gây sát thương trực tiếp (tùy game, có thể là DamageEvent, DealDamage...)
    pcall(function()
        damageRemote = RS:WaitForChild("DamageEvent", 10)
            or RS:WaitForChild("DealDamage", 10)
            or RS:WaitForChild("DamageRemote", 10)
            or RS.CombatSystem.Remotes:WaitForChild("DealDamage", 5)
    end)

    if hitRemote then print("[Kill Aura] Hit Remote: OK") else warn("[Kill Aura] Hit Remote: FAIL") end
    if abilityRemote then print("[Kill Aura] Ability Remote: OK") else warn("[Kill Aura] Ability Remote: FAIL") end
    if damageRemote then print("[Kill Aura] Damage Remote: OK") else warn("[Kill Aura] Damage Remote: NOT FOUND - sẽ dùng Hit Remote cho Mob") end
end

task.spawn(findRemotes)

local lastAttackTime = 0

local function fireAbilities()
    if not abilityRemote then return end
    pcall(function()
        abilityRemote:FireServer()
    end)
end

-- Hàm lấy Level và chỉ số tấn công của người chơi
local function getPlayerStats()
    local char = LocalPlayer.Character
    if not char then return 1, 10 end -- Mặc định Level 1, 10 damage
    
    -- Cách 1: Lấy từ leaderstats (phổ biến nhất)
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if leaderstats then
        local level = leaderstats:FindFirstChild("Level") or leaderstats:FindFirstChild("LVL")
        local damage = leaderstats:FindFirstChild("Damage") or leaderstats:FindFirstChild("Strength") or leaderstats:FindFirstChild("Attack")
        
        local lvl = (level and level.Value) or 1
        local dmg = (damage and damage.Value) or 10
        
        return lvl, dmg
    end
    
    -- Cách 2: Lấy từ character attributes (một số game dùng cách này)
    local levelAttr = char:GetAttribute("Level") or char:GetAttribute("LVL")
    local dmgAttr = char:GetAttribute("Damage") or char:GetAttribute("Strength") or char:GetAttribute("Attack")
    
    if levelAttr then return tonumber(levelAttr) or 1, tonumber(dmgAttr) or 10 end
    
    -- Cách 3: Tìm trong Player trực tiếp
    local levelVal = LocalPlayer:GetAttribute("Level")
    local dmgVal = LocalPlayer:GetAttribute("Damage")
    
    return tonumber(levelVal) or 1, tonumber(dmgVal) or 10
end

-- Hàm tính sát thương dựa trên chỉ số người chơi
local function calculateDamage()
    local level, baseDamage = getPlayerStats()
    
    -- Công thức tính sát thương: Có thể tùy chỉnh theo game của bạn
    -- Ví dụ: Mỗi Level tăng 5 damage, cộng với base damage
    local levelBonus = level * 5
    local totalDamage = baseDamage + levelBonus
    
    -- Thêm 1 chút ngẫu nhiên cho giống thật
    local randomBonus = math.random(-5, 5)
    totalDamage = totalDamage + randomBonus
    
    -- Đảm bảo sát thương luôn dương
    return math.max(totalDamage, 1)
end

-- Kiểm tra 1 đối tượng có phải mục tiêu hợp lệ không
local function isValidTarget(obj, char)
    -- Phải là Model
    if not obj:IsA("Model") then return false end
    -- Không phải người chơi
    if obj == char then return false end
    -- Bỏ qua Dummy
    if obj.Name == "Dummy" then return false end
    
    -- Có HumanoidRootPart
    local hrp = obj:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    -- Kiểm tra có Humanoid (mob) hoặc có máu (nguyên liệu)
    local hum = obj:FindFirstChildOfClass("Humanoid")
    
    if hum then
        -- Là mob/NPC: kiểm tra còn sống và HP%
        if hum.Health <= 0 then return false end
        local hpPct = (hum.Health / hum.MaxHealth) * 100
        if hpPct > AttackHPPercent then return false end
    else
        -- Là nguyên liệu: kiểm tra có thuộc tính máu không
        local health = obj:GetAttribute("Health") or obj:GetAttribute("HP")
        if health and tonumber(health) and tonumber(health) <= 0 then
            return false
        end
    end
    
    return true
end

-- Kiểm tra xem obj có phải là Mob/NPC không
local function isMob(obj)
    local hum = obj:FindFirstChildOfClass("Humanoid")
    return hum ~= nil
end

-- Gây sát thương cho Mob dựa trên chỉ số người chơi
local function damageMob(obj)
    local damage = calculateDamage()
    
    print("[Kill Aura] Gây " .. damage .. " sát thương lên " .. obj.Name .. " (Level: " .. getPlayerStats() .. ")")
    
    -- Cách 1: Nếu có damageRemote chuyên dụng
    if damageRemote then
        damageRemote:FireServer(obj, damage)
        return
    end
    
    -- Cách 2: Dùng hitRemote nhưng kèm theo thông tin sát thương
    -- Một số game cho phép truyền thêm damage vào hitRemote
    if hitRemote then
        -- Thử gửi với tham số damage (tùy game)
        pcall(function()
            hitRemote:FireServer(obj, damage)
        end)
        -- Nếu không được, fallback về cách đánh thường
        -- (sẽ gây sát thương mặc định của game)
        return
    end
    
    -- Cách 3: Trực tiếp thay đổi máu (nếu game cho phép client)
    -- KHÔNG KHUYẾN KHÍCH vì có thể bị phát hiện
    -- pcall(function()
    --     local hum = obj:FindFirstChildOfClass("Humanoid")
    --     if hum then
    --         hum.Health = hum.Health - damage
    --     end
    -- end)
end

-- Vòng lặp chính - Đánh TẤT CẢ mục tiêu trong TẤT CẢ thư mục
RunService.Heartbeat:Connect(function()
    if not KillAuraEnabled then return end
    if not hitRemote then return end

    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health <= 0 then return end

    local now = tick()
    if now - lastAttackTime < AttackCooldown then return end
    
    lastAttackTime = now
    local attackCount = 0
    local mobCount = 0
    local resourceCount = 0

    -- Duyệt qua TẤT CẢ thư mục mục tiêu
    for _, folder in ipairs(TargetFolders) do
        if not folder then continue end
        
        for _, obj in ipairs(folder:GetChildren()) do
            if not isValidTarget(obj, char) then continue end
            
            local objHrp = obj:FindFirstChild("HumanoidRootPart")
            if not objHrp then continue end
            
            local dist = (hrp.Position - objHrp.Position).Magnitude
            if dist > AttackRange then continue end

            -- Phân biệt Mob và Nguyên Liệu
            if isMob(obj) then
                -- LÀ MOB: Gây sát thương dựa trên chỉ số người chơi
                pcall(function()
                    if AttackMode == "Vector3" then
                        -- Vẫn gửi vị trí để kích hoạt animation đánh
                        hitRemote:FireServer(obj:GetPivot().Position)
                    else
                        hitRemote:FireServer(obj)
                    end
                    
                    -- Gây thêm sát thương tính theo chỉ số
                    damageMob(obj)
                end)
                mobCount = mobCount + 1
            else
                -- LÀ NGUYÊN LIỆU: Phá hủy ngay lập tức như cũ
                pcall(function()
                    if AttackMode == "Vector3" then
                        hitRemote:FireServer(obj:GetPivot().Position)
                    else
                        hitRemote:FireServer(obj)
                    end
                end)
                resourceCount = resourceCount + 1
            end

            -- Kích hoạt kỹ năng
            if FireAbilitiesEnabled then
                fireAbilities()
            end

            attackCount = attackCount + 1
        end
    end

    if attackCount > 0 then
        local lvl, dmg = getPlayerStats()
        print(string.format("[Kill Aura] Đã tấn công %d mục tiêu (Mob: %d - Sát thương: %d | Nguyên liệu: %d) - Level: %d, Damage: %d", 
            attackCount, mobCount, calculateDamage(), resourceCount, lvl, dmg))
    end
end)

print("[Kill Aura] Script loaded! Tấn công Mob (sát thương theo Level) & Nguyên liệu (phá hủy ngay)")

